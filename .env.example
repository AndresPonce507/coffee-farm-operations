# Supabase — anon (public) credentials for the read-only farm app.
# Safe to expose in the browser bundle: the database is protected by Row Level
# Security (anon may only SELECT). Copy this file to .env.local and fill in.
#
# Get the values from either:
#   • Supabase dashboard → Project Settings → API, or
#   • supabase projects api-keys --project-ref <your-ref>   (URL is https://<ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
